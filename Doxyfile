# Doxyfile for AnimaEngine project

# Project information
PROJECT_NAME           = "AnimaEngine"
PROJECT_NUMBER         = "1.0.0"
PROJECT_BRIEF          = "Nintendo DS Pokemon Black/White Sprite & Asset Extraction Studio"
OUTPUT_DIRECTORY       = docs

# Language & optimization
OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

# Input settings
INPUT                  = include source README.md THIRD_PARTY_NOTICES.md docs
FILE_PATTERNS          = *.c *.h *.md
RECURSIVE              = YES
EXCLUDE                = build/ docs/html/ release/ out/

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
SHOW_INCLUDE_FILES     = YES

# Warning settings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_LOGFILE           = docs/doxygen-warnings.log

# Output generation
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_LATEX         = NO
HAVE_DOT               = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

# Visual settings
HTML_COLORSTYLE        = DARK
USE_MDFILE_AS_MAINPAGE = README.md
